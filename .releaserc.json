{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "bash scripts/build-release-debs.sh ${nextRelease.version} && bash scripts/build-release-rpm.sh ${nextRelease.version}"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["CHANGELOG.md"]
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "release-debs/*.deb",
            "label": "Debian amd64 (.deb)"
          },
          {
            "path": "release-rpms/*.rpm",
            "label": "RPM x86_64 (.rpm) - Fedora"
          }
        ]
      }
    ]
  ]
}
