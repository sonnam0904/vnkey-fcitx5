# Ignore CMake build directories
/build/
**/build/
# CPack / scripts/build-deb.sh output (name is build-deb, not build)
**/build-deb/
**/build-rpm/

# CMake-generated files
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile

# Editor / IDE junk
.vscode/
.idea/
*.swp
*.swo
*~

# Node / JS
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Debian packages (built locally or by CI; do not commit)
*.deb
*.rpm

# semantic-release dual-target .deb output
/release-debs/
/release-rpms/
